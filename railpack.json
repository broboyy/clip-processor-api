{
  "provider": "python",
  "packages": {
    "ffmpeg": "latest"
  },
  "aptPackages": ["pkg-config", "libavformat-dev", "libavcodec-dev", "libavutil-dev", "libavfilter-dev", "libswscale-dev", "libswresample-dev"],
  "install": {
    "cmds": [
      "pip install --upgrade pip setuptools wheel",
      "pip install -r requirements.txt"
    ]
  },
  "start": {
    "cmd": "gunicorn main:app --bind 0.0.0.0:$PORT --timeout 600 --workers 1"
  }
}
