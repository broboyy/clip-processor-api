{
  "provider": "python",
  "python": {
    "version": "3.11.9"
  },
  "packages": {
    "ffmpeg": "latest",
    "pkg-config": "latest"
  },
  "install": {
    "cmds": [
      "pip install --upgrade pip setuptools wheel",
      "pip install -r requirements.txt"
    ]
  },
  "start": {
    "cmd": "gunicorn main:app --bind 0.0.0.0:$PORT --timeout 600 --workers 1"
  }
}
