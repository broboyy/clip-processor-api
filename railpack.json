{
  "providers": {
    "python": {
      "version": "3.11"
    }
  },
  "packages": {
    "ffmpeg": "latest"
  },
  "build": {
    "cmds": [
      "pip install --upgrade setuptools wheel pip",
      "pip install -r requirements.txt"
    ]
  },
  "deploy": {
    "cmd": "gunicorn main:app --bind 0.0.0.0:$PORT --timeout 600 --workers 1"
  }
}
